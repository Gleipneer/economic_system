# Copy this file to `.env` for local development.
#
# Current runtime variables used by the app:
DATABASE_URL=sqlite:///./database.db
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploaded_files
CORS_ALLOW_ORIGINS=*
AUTO_CREATE_SCHEMA=true
#
# Current OpenAI runtime variables.
# `OPENAI_MODEL` is the shared fallback if the flow-specific variables are not set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_INGEST_MODEL=gpt-5.4-mini
ECON_AI_MODEL_ROUTING_ENABLED=true
ECON_AI_DEFAULT_MODEL=
ECON_AI_STRUCTURED_MODEL=
ECON_AI_DEEP_ANALYSIS_MODEL=
ECON_AI_FALLBACK_MODEL=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=45
